    private static string RelativeTime(DateTimeOffset updatedAt)
    {
        var elapsed = DateTimeOffset.UtcNow - updatedAt.ToUniversalTime();
        if (elapsed.TotalMinutes < 2)
        {
            return "اکنون";
        }

        if (elapsed.TotalHours < 1)
        {
            return $"{(int)elapsed.TotalMinutes} دقیقه پیش";
        }

        if (elapsed.TotalDays < 1)
        {
            return $"{(int)elapsed.TotalHours} ساعت پیش";
        }

        return $"{(int)elapsed.TotalDays} روز پیش";
    }

