    private static IReadOnlyList<string> SupportedClrTypes { get; } =
    [
        "Guid",
        "string",
        "int",
        "long",
        "decimal",
        "Enum",
        "bool",
        "DateTime"
    ];

    private static IReadOnlyList<string> HttpVerbs { get; } =
    [
        "GET",
        "POST",
        "PUT",
        "PATCH",
        "DELETE"
    ];

    private DataObjectDefinition CurrentEntity
    {
        get
        {
            if (CurrentState.DataObjects.Count == 0)
            {
                CurrentState.DataObjects.Add(CreateDefaultDataObject());
            }

            return CurrentState.DataObjects[0];
        }
    }

    private IReadOnlyList<ApiEndpointDefinition> EntityMethods
    {
        get
        {
            EnsureEntityMethods();
            return CurrentState.ApiEndpoints
                .Where(endpoint => string.Equals(endpoint.Feature, Pluralize(NormalizeIdentifier(CurrentEntity.EntityName, "Entity")), StringComparison.Ordinal))
                .ToList();
        }
    }

    private async Task GenerateFromInputAsync()
    {
        if (IsGenerating)
        {
            return;
        }

        IsGenerating = true;
        GenerationFinished = false;
        GenerationErrors = [];
        GeneratedOutputPath = null;
        CurrentWizardStep = 6;
        CurrentState.CurrentStep = WizardStep.Generate;
        CurrentProjectId = await SaveDraftAsync("Generation requested from visual wizard.");
        await InvokeAsync(StateHasChanged);

        try
        {
            var metadata = BuildMetadataFromWizard();
            var result = GenerationService.Generate(metadata);

            GenerationErrors = result.Errors;
            GeneratedOutputPath = result.OutputPath;
            GenerationFinished = result.Errors.Count == 0;
        }
        catch
        {
            GenerationErrors = ["تولید پروژه انجام نشد. تنظیمات ورودی را بررسی کنید و دوباره تلاش کنید."];
            GeneratedOutputPath = null;
            GenerationFinished = false;
        }
        finally
        {
            IsGenerating = false;
        }

        if (CurrentProjectId is { } projectId)
        {
            var message = GenerationFinished
                ? $"Generation completed. Output: {GeneratedOutputPath}"
                : $"Generation failed. Errors: {string.Join(" | ", GenerationErrors)}";
            await WorkspaceStore.AddGenerationLogAsync(projectId, GenerationFinished ? "Information" : "Error", message);
        }
    }

    private ServiceMetadata BuildMetadataFromWizard()
    {
        var serviceName = BuildOutputServiceName();
        var entities = CurrentState.DataObjects
            .Where(entity => !string.IsNullOrWhiteSpace(entity.EntityName))
            .Select(entity => new EntityMetadata
            {
                Name = NormalizeIdentifier(entity.EntityName, "GeneratedEntity"),
                GenerateCrud = true,
                Fields = BuildFields(entity, NormalizeIdentifier(entity.EntityName, "GeneratedEntity")).ToList(),
                Methods = BuildMethods(entity).ToList()
            })
            .ToList();

        if (entities.Count == 0)
        {
            entities.Add(new EntityMetadata
            {
                Name = "GeneratedEntity",
                GenerateCrud = true,
                Fields =
                [
                    new() { Name = "Id", Type = "Guid", Required = true },
                    new() { Name = "Name", Type = "string", Required = true }
                ],
                Methods = []
            });
        }

        return new ServiceMetadata
        {
            ServiceName = serviceName,
            TargetFramework = CurrentState.Project.TargetFramework,
            Architecture = SelectedArchitecture,
            Database = "postgresql",
            Entities = entities
        };
    }

    private static IEnumerable<FieldMetadata> BuildFields(DataObjectDefinition entity, string entityName)
    {
        var fields = entity.Fields
            .Where(field => field.IncludeInEntity && !string.IsNullOrWhiteSpace(field.PropertyName))
            .Select(field => new FieldMetadata
            {
                Name = NormalizeFieldName(field.PropertyName, entityName),
                Type = field.ClrType == "Enum"
                    ? "string"
                    : SupportedClrTypes.Contains(field.ClrType) ? field.ClrType : "string",
                Required = field.IsPrimaryKey || !field.IsNullable
            })
            .ToList();

        if (!fields.Any(field => field.Name == "Id" && field.Type == "Guid"))
        {
            fields.Insert(0, new FieldMetadata { Name = "Id", Type = "Guid", Required = true });
        }

        return fields
            .GroupBy(field => field.Name, StringComparer.Ordinal)
            .Select(group => group.First());
    }

    private IEnumerable<MethodMetadata> BuildMethods(DataObjectDefinition entity)
    {
        var entityName = NormalizeIdentifier(entity.EntityName, "Entity");
        var feature = Pluralize(entityName);
        EnsureEntityMethods();

        return CurrentState.ApiEndpoints
            .Where(endpoint => string.Equals(endpoint.Feature, feature, StringComparison.Ordinal))
            .Where(endpoint => !string.IsNullOrWhiteSpace(endpoint.Name))
            .Select(endpoint => new MethodMetadata
            {
                Name = NormalizeIdentifier(endpoint.Name, $"{endpoint.OperationType}{entityName}"),
                HttpMethod = NormalizeHttpMethod(endpoint.Method),
                Route = NormalizeRoute(endpoint.Route, entityName),
                OperationType = endpoint.OperationType == "Command" ? "Command" : "Query",
                RequestDto = NormalizeOptionalIdentifier(endpoint.RequestDto),
                ResponseDto = NormalizeOptionalIdentifier(endpoint.ResponseDto),
                UsesPaging = endpoint.UsesPaging,
                UsesDatabase = endpoint.UsesDatabase,
                UsesExternalService = endpoint.UsesExternalService,
                ExternalServiceName = NormalizeOptionalIdentifier(endpoint.ExternalServiceName),
                UsesCache = endpoint.UsesCache,
                UsesMessageLog = endpoint.UsesMessageLog,
                UsesEncryption = endpoint.UsesEncryption
            })
            .GroupBy(method => method.Name, StringComparer.Ordinal)
            .Select(group => group.First());
    }

    private static string NormalizeHttpMethod(string value) =>
        HttpVerbs.Contains(value.ToUpperInvariant()) ? value.ToUpperInvariant() : "GET";

    private static string NormalizeRoute(string? route, string entityName)
    {
        if (!string.IsNullOrWhiteSpace(route))
        {
            return route.Trim();
        }

        return $"/api/{ToKebabCase(Pluralize(entityName))}";
    }

    private static string NormalizeOptionalIdentifier(string? value) =>
        string.IsNullOrWhiteSpace(value) ? string.Empty : NormalizeIdentifier(value, string.Empty);

    private static string NormalizeFieldName(string? value, string entityName)
    {
        var fieldName = NormalizeIdentifier(value, "Field");
        return string.Equals(fieldName, entityName, StringComparison.Ordinal)
            ? $"{fieldName}Value"
            : fieldName;
    }

    private void AddField()
    {
        var index = CurrentEntity.Fields.Count + 1;
        CurrentEntity.Fields.Add(new FieldMappingDefinition
        {
            SourceName = $"field_{index}",
            PropertyName = $"Field{index}",
            DbType = "varchar",
            ClrType = "string",
            IncludeInEntity = true
        });
    }

    private void RemoveField(FieldMappingDefinition field)
    {
        CurrentEntity.Fields.Remove(field);
        if (CurrentEntity.Fields.Count == 0)
        {
            AddField();
        }
    }

    private static string FieldRole(FieldMappingDefinition field)
    {
        if (field.IsPrimaryKey)
        {
            return "PK";
        }

        if (field.PropertyName.EndsWith("Id", StringComparison.Ordinal) && field.ClrType == "Guid")
        {
            return "FK";
        }

        return field.IsNullable ? "Optional" : "Required";
    }

    private static void SetFieldRole(FieldMappingDefinition field, string? role)
    {
        field.IsPrimaryKey = role == "PK";
        field.IsNullable = role == "Optional";
        if (role == "PK" || role == "FK")
        {
            field.ClrType = "Guid";
        }
    }

    private async Task SuggestMethodsFromEntityAsync()
    {
        ResetEntityMethods();
        EntityDesignerStep = 1;
        CurrentProjectId = await SaveDraftAsync($"Methods suggested for entity: {CurrentEntity.EntityName}.");
    }

    private void AddEntityMethod()
    {
        var entityName = NormalizeIdentifier(CurrentEntity.EntityName, "Entity");
        var feature = Pluralize(entityName);
        var methodIndex = CurrentState.ApiEndpoints.Count(endpoint => endpoint.Feature == feature) + 1;
        CurrentState.ApiEndpoints.Add(new ApiEndpointDefinition
        {
            Name = $"Custom{entityName}Method{methodIndex}",
            Feature = feature,
            Method = "POST",
            Route = $"/api/{ToKebabCase(Pluralize(entityName))}/custom-{methodIndex}",
            OperationType = "Command",
            RequestDto = $"{entityName}Request",
            ResponseDto = $"{entityName}Response",
            UsesPaging = NewMethodUsesPaging,
            UsesDatabase = true,
            UsesExternalService = NewMethodUsesExternalService,
            ExternalServiceName = NewMethodUsesExternalService
                ? (CurrentState.ExternalServices.FirstOrDefault()?.Name ?? "ExternalService")
                : string.Empty,
            UsesCache = NewMethodUsesCache,
            UsesMessageLog = NewMethodUsesMessageLog,
            UsesEncryption = NewMethodUsesEncryption
        });
    }

    private async Task AddEntityMethodAsync()
    {
        AddEntityMethod();
        CurrentProjectId = await SaveDraftAsync("Entity method added from visual wizard.");
    }

    private void RemoveEntityMethod(ApiEndpointDefinition method)
    {
        CurrentState.ApiEndpoints.Remove(method);
    }

    private async Task RemoveEntityMethodAsync(ApiEndpointDefinition method)
    {
        RemoveEntityMethod(method);
        CurrentProjectId = await SaveDraftAsync($"Entity method removed: {method.Name}.");
    }

    private void ResetEntityMethods()
    {
        var entityName = NormalizeIdentifier(CurrentEntity.EntityName, "Entity");
        var feature = Pluralize(entityName);
        CurrentState.ApiEndpoints.RemoveAll(endpoint => endpoint.Feature == feature);
        AddCrudMethods(entityName);
    }

    private async Task ResetEntityMethodsAsync()
    {
        ResetEntityMethods();
        CurrentProjectId = await SaveDraftAsync("Entity methods reset to CRUD defaults.");
    }

    private void EnsureEntityMethods()
    {
        var entityName = NormalizeIdentifier(CurrentEntity.EntityName, "Entity");
        var feature = Pluralize(entityName);
        if (!CurrentState.ApiEndpoints.Any(endpoint => endpoint.Feature == feature))
        {
            AddCrudMethods(entityName);
        }
    }

    private void AddCrudMethods(string entityName)
    {
        var feature = Pluralize(entityName);
        var routeBase = $"/api/{ToKebabCase(feature)}";
        CurrentState.ApiEndpoints.AddRange(
        [
            new()
            {
                Name = $"Create{entityName}",
                Feature = feature,
                Method = "POST",
                Route = routeBase,
                OperationType = "Command",
                RequestDto = $"Create{entityName}Request",
                ResponseDto = $"{entityName}Response"
            },
            new()
            {
                Name = $"Update{entityName}",
                Feature = feature,
                Method = "PUT",
                Route = $"{routeBase}/{{id}}",
                OperationType = "Command",
                RequestDto = $"Update{entityName}Request",
                ResponseDto = $"{entityName}Response"
            },
            new()
            {
                Name = $"Get{entityName}ById",
                Feature = feature,
                Method = "GET",
                Route = $"{routeBase}/{{id}}",
                OperationType = "Query",
                ResponseDto = $"{entityName}Response"
            },
            new()
            {
                Name = $"Search{Pluralize(entityName)}",
                Feature = feature,
                Method = "GET",
                Route = routeBase,
                OperationType = "Query",
                ResponseDto = $"{entityName}Response",
                UsesPaging = true
            },
            new()
            {
                Name = $"Delete{entityName}",
                Feature = feature,
                Method = "DELETE",
                Route = $"{routeBase}/{{id}}",
                OperationType = "Command"
            }
        ]);
    }

    private string EntityPreviewText()
    {
        EnsureEntityMethods();
        var builder = new System.Text.StringBuilder();
        var serviceName = BuildOutputServiceName();
        builder.AppendLine($"{serviceName}/");
        builder.AppendLine($"├── src/{serviceName}.Api/Controllers/{CurrentEntity.EntityName}Controller.cs");
        builder.AppendLine($"├── src/{serviceName}.Application/Features/{Pluralize(CurrentEntity.EntityName)}/");
        builder.AppendLine($"│   ├── DTOs/{CurrentEntity.EntityName}Dto.cs");
        if (SelectedArchitecture == "CQRS + MediatR")
        {
            builder.AppendLine("│   ├── Commands/");
            builder.AppendLine("│   └── Queries/");
        }
        else
        {
            builder.AppendLine($"│   ├── DTOs/Create{CurrentEntity.EntityName}Input.cs");
            builder.AppendLine($"│   ├── DTOs/Update{CurrentEntity.EntityName}Input.cs");
            builder.AppendLine("│   └── Operations/");
        }
        builder.AppendLine($"└── src/{serviceName}.Domain/Entities/{CurrentEntity.EntityName}.cs");
        builder.AppendLine();
        builder.AppendLine("Fields:");
        foreach (var field in CurrentEntity.Fields)
        {
            builder.AppendLine($"- {field.PropertyName}: {field.ClrType} ({FieldRole(field)})");
        }

        builder.AppendLine();
        builder.AppendLine("API Methods:");
        foreach (var method in EntityMethods)
        {
            builder.AppendLine($"- {method.Method} {method.Route} => {method.Name} ({method.OperationType})");
        }

        return builder.ToString();
    }

