    private async Task SelectDatabaseTableAsync(DatabaseTablePreview table)
    {
        CurrentEntity.Kind = "Table";
        CurrentEntity.Schema = table.Schema;
        CurrentEntity.DatabaseName = table.Name;
        CurrentEntity.EntityName = ToPascalCase(Singularize(table.Name));
        CurrentEntity.Fields = table.Columns.Select(CreateFieldFromColumn).ToList();
        CurrentProjectId = await SaveDraftAsync($"Database table selected: {table.Schema}.{table.Name}.");
    }

    private async Task AddColumnAsync(DatabaseColumnPreview column)
    {
        if (!CurrentEntity.Fields.Any(field => string.Equals(field.SourceName, column.Name, StringComparison.OrdinalIgnoreCase)))
        {
            CurrentEntity.Fields.Add(CreateFieldFromColumn(column));
        }

        CurrentProjectId = await SaveDraftAsync($"Database column selected: {column.Name}.");
    }

    private async Task RemoveColumnAsync(DatabaseColumnPreview column)
    {
        if (column.Role == "PK")
        {
            PlatformMessage = "ستون کلید اصلی از موجودیت حذف نمی‌شود.";
            return;
        }

        CurrentEntity.Fields.RemoveAll(field => string.Equals(field.SourceName, column.Name, StringComparison.OrdinalIgnoreCase));
        CurrentProjectId = await SaveDraftAsync($"Database column removed: {column.Name}.");
    }

    private async Task SelectAllColumnsAsync()
    {
        if (CurrentSelectedTable is not { } table)
        {
            return;
        }

        CurrentEntity.Fields = table.Columns.Select(CreateFieldFromColumn).ToList();
        CurrentProjectId = await SaveDraftAsync($"All columns selected for table: {table.Name}.");
    }

    private async Task DeselectAllColumnsAsync()
    {
        if (CurrentSelectedTable is not { } table)
        {
            return;
        }

        CurrentEntity.Fields = table.Columns
            .Where(column => column.Role == "PK")
            .Select(CreateFieldFromColumn)
            .ToList();
        CurrentProjectId = await SaveDraftAsync($"Non-primary columns deselected for table: {table.Name}.");
    }

    private static FieldMappingDefinition CreateFieldFromColumn(DatabaseColumnPreview column) => new()
    {
        SourceName = column.Name,
        PropertyName = ToPascalCase(column.Name),
        DbType = column.Type,
        ClrType = MapPostgresType(column.Type),
        IsPrimaryKey = column.Role == "PK",
        IsNullable = column.Role == "Optional",
        IncludeInEntity = true
    };

    private RenderFragment ColumnRoleBadge(DatabaseColumnPreview column) =>
        @<small class="mg-col-role @column.Role.ToLowerInvariant()">@column.Role</small>;

    private static string MapPostgresType(string type) => type.ToLowerInvariant() switch
    {
        "uuid" => "Guid",
        "int" or "integer" => "int",
        "bigint" => "long",
        "numeric" or "decimal" => "decimal",
        "timestamp" or "timestamptz" or "date" => "DateTime",
        "boolean" or "bool" => "bool",
        _ => "string"
    };

    private static string Singularize(string value) =>
        value.EndsWith("ies", StringComparison.OrdinalIgnoreCase)
            ? $"{value[..^3]}y"
            : value.EndsWith('s') && value.Length > 1 ? value[..^1] : value;

    private static string ToPascalCase(string value)
    {
        var parts = value.Split(['_', '-', ' ', '.'], StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0)
        {
            return "GeneratedEntity";
        }

        return string.Concat(parts.Select(part =>
            char.ToUpperInvariant(part[0]) + (part.Length > 1 ? part[1..] : string.Empty)));
    }

